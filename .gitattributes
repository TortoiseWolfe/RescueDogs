# Normalize line endings across platforms.
# Without this, Windows checkouts (core.autocrlf=true) write CRLF into shell
# scripts, which Linux/Docker cannot execute (entrypoint + dev server crash).

# Default: let git handle text normalization automatically.
* text=auto

# Files that MUST stay LF regardless of platform (executed by sh/bash in Docker).
*.sh text eol=lf
*.bash text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-entrypoint.sh text eol=lf
.husky/* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Common text formats — keep LF in the repo.
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.svg text eol=lf
*.sql text eol=lf
*.toml text eol=lf

# Binary files — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
